# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
pytest-cache-files-*/
.ruff_cache/
.mypy_cache/

# Virtual envs
.venv/
venv/
env/

# IDE
.vscode/
.idea/
*.swp
.DS_Store

# Claude Code (per-machine; shared config goes in .claude/settings.json or .claude/launch.json)
.claude/settings.local.json

# Data caches (regeneratable)
data/raw/*
!data/raw/.gitkeep
# news_sentiment collector cache — timestamped raw items per (ticker, source).
# Persisted on disk so the data clock survives across runs, but not tracked
# (size + per-machine).
data/news/*
!data/news/.gitkeep

# Generated outputs
reports/*
!reports/.gitkeep
artifacts/models/*
!artifacts/models/.gitkeep
artifacts/predictions/*
!artifacts/predictions/.gitkeep
# manifest.json is regenerated by lidr_core.eval.leaderboard from whatever
# artifacts happen to be on disk; treat it as a build output, not source.
artifacts/manifest.json
# LLM spend log is a per-machine cost record; not source-of-truth.
artifacts/llm_spend.csv

# Jupyter
.ipynb_checkpoints/
*.ipynb
